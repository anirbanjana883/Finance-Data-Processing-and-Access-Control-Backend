generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

// ENUMS

enum Role {
  MASTER_ADMIN  // System level: Creates Organizations
  ADMIN         // Org level: Full control (CEO/HR/Manager)
  ANALYST       // Org level: Data insights (Read-only records)
  VIEWER        // Org level: Dashboard only
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  ACTIVE
  ARCHIVED
}

enum AuditAction {
  ROLE_UPDATED
  STATUS_UPDATED
  USER_CREATED
  USER_DELETED
  TRANSACTION_CREATED
  TRANSACTION_UPDATED
  TRANSACTION_DELETED
}

// MODELS

// THE TENANT (ORGANIZATION)
model Organization {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  
  users        User[]
  transactions Transaction[]
  auditLogs    AuditLog[]  

  @@map("organizations")
}

// THE ORG-SCOPED USER
model User {
  id           String       @id @default(uuid())
  name         String
  email        String       
  passwordHash String
  role         Role         @default(VIEWER)
  status       UserStatus   @default(ACTIVE)
  
  orgId        String?      
  organization Organization? @relation(fields: [orgId], references: [id])

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?    

  transactions Transaction[] @relation("UserTransactions")

  actionsPerformed AuditLog[] @relation("ActorLogs")
  actionsReceived  AuditLog[] @relation("TargetLogs")

  // Allows the same email to exist in different Orgs, but only once per Org.
  @@unique([email, orgId]) 
  @@map("users")
}

//  THE FINANCIAL RECORD
model Transaction {
  id          String          @id @default(uuid())
  
  //  Semantic Ownership Shift
  createdById String          
  createdBy   User            @relation("UserTransactions", fields: [createdById], references: [id])
  
  //  SECURITY LAYER: Hardcoded link to the Org
  orgId       String          
  organization Organization   @relation(fields: [orgId], references: [id])
  
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(ACTIVE)
  category    String
  date        DateTime        @default(now())
  notes       String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?       

  //  Composite Indexes for fust dashboard filtering 
  @@index([orgId, date])      
  @@index([orgId, category])
  @@index([orgId, type])
  @@index([orgId, date, type])
  @@index([createdById, date])

  @@map("transactions")
}

//  THE AUDIT TRAIL
model AuditLog {
  id        String   @id @default(uuid())
  
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id])

  actorId   String
  actor     User     @relation("ActorLogs", fields: [actorId], references: [id])

  targetId  String?  
  target    User?    @relation("TargetLogs", fields: [targetId], references: [id])

  action    AuditAction 
  oldValue  String?  
  newValue  String?  
  
  createdAt DateTime @default(now())

  @@index([orgId, createdAt]) 
  @@map("audit_logs")
}